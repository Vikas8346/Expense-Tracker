{
  "buildCommand": "pip install -r requirements.txt",
  "runtime": "python3.11",
  "env": {
    "ANTHROPIC_API_KEY": "@anthropic_api_key",
    "SECRET_KEY": "@secret_key",
    "DISABLE_TESSERACT": "true",
    "FLASK_ENV": "production"
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
